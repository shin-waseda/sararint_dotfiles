#===========================================================

# Stable LuaLaTeX latexmkrc

#===========================================================

# カレントディレクトリへ移動

$do_cd = 1;

#-----------------------------------------------------------

# LuaLaTeX

#-----------------------------------------------------------
$pdf_mode = 4;

$lualatex = 'lualatex '
. '-synctex=1 '
. '-interaction=nonstopmode '
. '-file-line-error '
. '-halt-on-error '
. '%O %S';

$max_repeat = 5;

#-----------------------------------------------------------

# bibliography

#-----------------------------------------------------------
$bibtex_use = 2;

$biber = 'biber '
. '--bblencoding=utf8 '
. '-u -U '
. '--output_safechars '
. '%O %S';

#-----------------------------------------------------------

# index

#-----------------------------------------------------------
$makeindex = 'upmendex %O -o %D %S -s jpbase';

#-----------------------------------------------------------

# Viewer

# Linux + VSCodeなら不要

#-----------------------------------------------------------

# $pdf_previewer = 'xdg-open %S';

#-----------------------------------------------------------

# 出力

#-----------------------------------------------------------
# $out_dir = ".";
# 出力先ディレクトリを指定（buildフォルダにまとめる例）
$out_dir = 'build';

#-----------------------------------------------------------

# clean対象

#-----------------------------------------------------------
$clean_ext .= " run.xml";
$clean_ext .= " synctex.gz";
$clean_ext .= " nav";
$clean_ext .= " snm";
$clean_ext .= " vrb";

#-----------------------------------------------------------

# latexmk安定化

#-----------------------------------------------------------
$force_mode = 1;

$pvc_view_file_via_temporary = 0;

$sleep_time = 1;

$diagnostics = 1;

print "LuaLaTeX stable latexmkrc loaded.\n";
